# Copy to `.env` in the project root and fill in values. Scripts load it from cwd (see scripts/loadDotenv.ts).

# Optional: override Playwright storage state path (default: .auth/barbora-storage-state.json under cwd)
# BARBORA_STORAGE_STATE_PATH=

# LLM fallback (cart-prep): set enabled + API key to use after deterministic review_needed
# BARBORA_LLM_ENABLED=true
# BARBORA_LLM_API_KEY=
# BARBORA_LLM_PROVIDER=openai|gemini
# BARBORA_LLM_BASE_URL=
# BARBORA_LLM_MODEL=
# BARBORA_LLM_TIMEOUT_MS=
